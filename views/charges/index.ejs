<style>
  .cat-wrapper { padding: 28px 20px; background: #f8fafc; min-height: 100vh; }
  .page-heading { font-size: 22px; font-weight: 700; color: #0f172a; margin-bottom: 24px; }
  .page-heading span { color: #e63946; }

  .dash-card { background: #fff; border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.07); overflow: hidden; margin-bottom: 28px; }
  .dash-card-header { background: #0f172a; padding: 16px 22px; display: flex; align-items: center; gap: 10px; }
  .dash-card-header i { color: #e63946; font-size: 20px; }
  .dash-card-header span { color: #fff; font-size: 15px; font-weight: 600; }
  .dash-card-body { padding: 22px; }

  .cat-table { width: 100%; border-collapse: separate; border-spacing: 0; }
  .cat-table thead tr th { background: #0f172a; color: rgba(255,255,255,0.75); font-size: 12px; font-weight: 600; letter-spacing: 0.6px; text-transform: uppercase; padding: 13px 16px; border: none; white-space: nowrap; }
  .cat-table thead tr th:first-child { border-radius: 10px 0 0 0; }
  .cat-table thead tr th:last-child  { border-radius: 0 10px 0 0; }
  .cat-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.15s; }
  .cat-table tbody tr:hover { background: #fafafa; }
  .cat-table tbody tr:last-child { border-bottom: none; }
  .cat-table tbody td { padding: 13px 16px; font-size: 13.5px; color: #334155; vertical-align: middle; }

  .sno-badge { background: #f1f5f9; color: #64748b; font-size: 12px; font-weight: 600; padding: 3px 9px; border-radius: 6px; }
  .amount-badge { background: #f0fdf4; color: #16a34a; font-weight: 700; font-size: 13px; padding: 3px 10px; border-radius: 6px; }

  .btn-edit { background: #eff6ff; color: #3b82f6; border: none; border-radius: 8px; padding: 5px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .btn-edit:hover { background: #3b82f6; color: #fff; }

  /* addon cards grid */
  .addon-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; padding: 22px; }
  .addon-card { background: #fff; border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 18px; transition: box-shadow 0.2s; }
  .addon-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); border-color: #e63946; }
  .addon-card-id { font-size: 11px; font-weight: 700; color: #e63946; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; background: #fff1f2; display: inline-block; padding: 3px 10px; border-radius: 20px; }
  .addon-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #f1f5f9; }
  .addon-row:last-of-type { border-bottom: none; }
  .addon-row label { font-size: 12px; color: #64748b; font-weight: 500; }
  .addon-row .val { font-size: 13.5px; font-weight: 700; color: #0f172a; background: #f8fafc; padding: 2px 8px; border-radius: 6px; }
  .btn-update-addon { width: 100%; margin-top: 14px; background: linear-gradient(135deg,#e63946,#c1121f); color: #fff; border: none; border-radius: 10px; padding: 9px; font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
  .btn-update-addon:hover { opacity: 0.88; }

  /* form */
  .form-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; display: block; }
  .form-control { border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 13.5px; padding: 9px 14px; color: #1e293b; width: 100%; outline: none; transition: border-color 0.2s; }
  .form-control:focus { border-color: #e63946; box-shadow: 0 0 0 3px rgba(230,57,70,0.1); }

  .btn-save { background: linear-gradient(135deg,#e63946,#c1121f); color:#fff; border:none; border-radius:10px; padding:10px 28px; font-size:14px; font-weight:600; cursor:pointer; transition:opacity 0.2s; }
  .btn-save:hover { opacity: 0.88; }

  /* modal */
  .modal-content { border: none; border-radius: 16px; overflow: hidden; }
  .modal-header-dark { background: #0f172a; padding: 16px 22px; display: flex; align-items: center; justify-content: space-between; }
  .modal-header-dark span { color: #fff; font-size: 15px; font-weight: 600; }
  .modal-header-dark button { background: none; border: none; color: rgba(255,255,255,0.6); font-size: 20px; cursor: pointer; }

  /* toast */
  .toast-msg { position: fixed; top: 24px; right: 24px; z-index: 99999; background: #0f172a; color: #fff; padding: 14px 22px; border-radius: 12px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.2); opacity: 0; transform: translateY(-10px); transition: all 0.3s ease; pointer-events: none; }
  .toast-msg.show { opacity: 1; transform: translateY(0); }
  .toast-msg i { color: #22c55e; font-size: 18px; }

  .empty-state { text-align: center; padding: 40px; color: #94a3b8; }
  .empty-state i { font-size: 40px; display: block; margin-bottom: 8px; }
</style>

<div class="cat-wrapper">

  <div class="page-heading">
    <i class="las la-money-bill" style="color:#e63946; margin-right:8px;"></i>
    Manage <span>Charges</span>
  </div>

  <!-- ── CHARGES TABLE ── -->
  <div class="dash-card">
    <div class="dash-card-header">
      <i class="las la-list-alt"></i>
      <span>Charges List</span>
    </div>
    <div style="padding:0;">
      <div class="table-responsive">
        <table class="cat-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Charge Name</th>
              <th>Amount</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (charges && charges.length > 0) { %>
              <% charges.forEach((charge, idx) => { %>
                <tr id="chargeRow-<%= charge.id %>">
                  <td><span class="sno-badge"><%= idx + 1 %></span></td>
                  <td style="font-weight:600; color:#0f172a;" class="charge_name"><%= charge.charge_name %></td>
                  <td>
                    <%
                      const cn = (charge.charge_name || '').toLowerCase();
                      const isPercent = cn.includes('gst') || cn.includes('percent') || cn.includes('wallet') || cn.includes('deduction');
                    %>
                    <span class="amount-badge charge_amount">
                      <% if (isPercent) { %>
                        <%= charge.amount %>%
                      <% } else { %>
                        ₹<%= charge.amount %>
                      <% } %>
                    </span>
                  </td>
                  <td>
                    <button class="btn-edit editBtn"
                      data-id="<%= charge.id %>"
                      data-name="<%= charge.charge_name %>"
                      data-amount="<%= charge.amount %>">
                      <i class="las la-pen"></i> Edit
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4"><div class="empty-state"><i class="las la-money-bill"></i><p>No charges found.</p></div></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── ADDON CHARGES CARDS ── -->
  <div class="dash-card">
    <div class="dash-card-header">
      <i class="las la-truck"></i>
      <span>Addon Delivery Charges</span>
    </div>
    <% if (addonCharges && addonCharges.length > 0) { %>
      <div class="addon-grid">
        <% addonCharges.forEach((ac, idx) => { %>
          <div class="addon-card">
            <div class="addon-card-id">Record #<%= idx + 1 %></div>
            <div class="addon-row"><label>Base Delivery Charge</label><span class="val">₹<%= ac.base_delivery_charge %></span></div>
            <div class="addon-row"><label>Admin Charge</label><span class="val">₹<%= ac.admin_charge %></span></div>
            <div class="addon-row"><label>Base Delivery Distance</label><span class="val"><%= ac.base_delivery_distance %> km</span></div>
            <div class="addon-row"><label>Addon Charge / km</label><span class="val">₹<%= ac.addon_charge %></span></div>
            <div class="addon-row"><label>Est. Distance / km</label><span class="val"><%= ac.estimated_distance_per_km %> km</span></div>
            <button class="btn-update-addon"
              data-id="<%= ac.id %>"
              data-base="<%= ac.base_delivery_charge %>"
              data-admin="<%= ac.admin_charge %>"
              data-dist="<%= ac.base_delivery_distance %>"
              data-addon="<%= ac.addon_charge %>"
              data-est="<%= ac.estimated_distance_per_km %>">
              <i class="las la-pen"></i> Update Amounts
            </button>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state"><i class="las la-truck"></i><p>No addon charges found.</p></div>
    <% } %>
  </div>

</div>

<!-- Edit Charge Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header-dark">
        <span><i class="las la-pen" style="color:#e63946;margin-right:8px;"></i>Edit Charge</span>
        <button type="button" onclick="closeModal('editModal')">✕</button>
      </div>
      <div class="dash-card-body">
        <form id="editForm">
          <input type="hidden" id="charge_id" name="id">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Charge Name</label>
              <input type="text" class="form-control" name="charge_name" id="charge_name" required>
            </div>
            <div class="col-12">
              <label class="form-label">Amount (₹)</label>
              <input type="number" step="0.01" class="form-control" name="amount" id="charge_amount" required>
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn-save">Update Charge</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Edit Addon Modal -->
<div class="modal fade" id="addonModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header-dark">
        <span><i class="las la-truck" style="color:#e63946;margin-right:8px;"></i>Update Addon Charges</span>
        <button type="button" onclick="closeModal('addonModal')">✕</button>
      </div>
      <div class="dash-card-body">
        <form id="addonForm">
          <input type="hidden" id="addon_id" name="id">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Base Delivery Charge (₹)</label>
              <input type="number" step="0.01" class="form-control" name="base_delivery_charge" id="a_base" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Admin Charge (₹)</label>
              <input type="number" step="0.01" class="form-control" name="admin_charge" id="a_admin" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Base Delivery Distance (km)</label>
              <input type="number" step="0.01" class="form-control" name="base_delivery_distance" id="a_dist" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Addon Charge per km (₹)</label>
              <input type="number" step="0.01" class="form-control" name="addon_charge" id="a_addon" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Estimated Distance per km</label>
              <input type="number" step="0.01" class="form-control" name="estimated_distance_per_km" id="a_est" required>
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn-save">Update Addon Charges</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-msg" id="toastMsg">
  <i class="las la-check-circle"></i>
  <span id="toastText">Updated successfully!</span>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function closeModal(id) {
    const m = bootstrap.Modal.getInstance(document.getElementById(id));
    if (m) m.hide();
  }

  function showToast(msg) {
    const t = document.getElementById('toastMsg');
    document.getElementById('toastText').textContent = msg || 'Updated successfully!';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

$(document).ready(function(){

  // Open charge edit modal
  $(document).on('click', '.editBtn', function(){
    $('#charge_id').val($(this).data('id'));
    $('#charge_name').val($(this).data('name'));
    $('#charge_amount').val($(this).data('amount'));
    new bootstrap.Modal(document.getElementById('editModal')).show();
  });

  // Submit charge update
  $('#editForm').submit(function(e){
    e.preventDefault();
    const id = $('#charge_id').val();
    $.post('/charges/update/' + id, $(this).serialize(), function(res){
      if(res.status){
        const row = $('#chargeRow-' + id);
        row.find('.charge_name').text($('#charge_name').val());
        row.find('.charge_amount').text('₹' + $('#charge_amount').val());
        closeModal('editModal');
        showToast('Charge updated successfully!');
      } else {
        alert(res.message || 'Update failed');
      }
    });
  });

  // Open addon edit modal
  $(document).on('click', '.btn-update-addon', function(){
    $('#addon_id').val($(this).data('id'));
    $('#a_base').val($(this).data('base'));
    $('#a_admin').val($(this).data('admin'));
    $('#a_dist').val($(this).data('dist'));
    $('#a_addon').val($(this).data('addon'));
    $('#a_est').val($(this).data('est'));
    new bootstrap.Modal(document.getElementById('addonModal')).show();
  });

  // Submit addon update
  $('#addonForm').submit(function(e){
    e.preventDefault();
    const id = $('#addon_id').val();
    $.post('/charges/addon/update/' + id, $(this).serialize(), function(res){
      if(res.success){
        closeModal('addonModal');
        showToast('Addon charges updated successfully!');
        setTimeout(() => location.reload(), 1500);
      } else {
        alert(res.message || 'Update failed');
      }
    });
  });

});
</script>
