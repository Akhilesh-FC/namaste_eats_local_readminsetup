<style>
  .cat-wrapper { padding: 28px 20px; background: #f8fafc; min-height: 100vh; }
  .page-heading { font-size: 22px; font-weight: 700; color: #0f172a; margin-bottom: 24px; }
  .page-heading span { color: #e63946; }

  .dash-card { background: #fff; border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.07); overflow: hidden; margin-bottom: 28px; }
  .dash-card-header { background: #0f172a; padding: 16px 22px; display: flex; align-items: center; gap: 10px; }
  .dash-card-header i { color: #e63946; font-size: 20px; }
  .dash-card-header span { color: #fff; font-size: 15px; font-weight: 600; }
  .dash-card-body { padding: 22px; }

  .form-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; display: block; }
  .form-control, .form-select { border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 13.5px; padding: 9px 14px; color: #1e293b; width: 100%; outline: none; transition: border-color 0.2s; }
  .form-control:focus { border-color: #e63946; box-shadow: 0 0 0 3px rgba(230,57,70,0.1); }

  .file-upload-wrapper input[type="file"] { display: none; }
  .file-upload-label { display: flex; align-items: center; gap: 10px; border: 1.5px dashed #e2e8f0; border-radius: 10px; padding: 10px 14px; cursor: pointer; background: #f8fafc; transition: border-color 0.2s; }
  .file-upload-label:hover { border-color: #e63946; background: #fff1f2; }
  .file-upload-label .upload-icon { width: 36px; height: 36px; background: #fff1f2; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #e63946; font-size: 18px; flex-shrink: 0; }
  .file-upload-label .upload-text { font-size: 13px; color: #64748b; }
  .file-upload-label .upload-text strong { display: block; color: #1e293b; font-size: 13.5px; }
  .file-name-display { font-size: 12px; color: #e63946; margin-top: 5px; display: none; }

  .btn-create { background: linear-gradient(135deg,#e63946,#c1121f); color:#fff; border:none; border-radius:10px; padding:10px 28px; font-size:14px; font-weight:600; cursor:pointer; transition:opacity 0.2s; }
  .btn-create:hover { opacity: 0.88; }

  /* search */
  .search-bar { padding: 16px 22px; border-bottom: 1px solid #f1f5f9; display: flex; gap: 10px; flex-wrap: wrap; }
  .search-bar input { flex:1; min-width:200px; max-width:360px; border:1.5px solid #e2e8f0; border-radius:10px; padding:9px 14px; font-size:13.5px; color:#1e293b; outline:none; transition:border-color 0.2s; }
  .search-bar input:focus { border-color:#e63946; box-shadow:0 0 0 3px rgba(230,57,70,0.1); }
  .btn-search { background:#0f172a; color:#fff; border:none; border-radius:10px; padding:9px 18px; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; text-decoration:none; }
  .btn-clear-s { background:#f1f5f9; color:#64748b; border:none; border-radius:10px; padding:9px 14px; font-size:13px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:6px; }

  /* table */
  .cat-table { width:100%; border-collapse:separate; border-spacing:0; }
  .cat-table thead tr th { background:#0f172a; color:rgba(255,255,255,0.75); font-size:12px; font-weight:600; letter-spacing:0.6px; text-transform:uppercase; padding:13px 16px; border:none; white-space:nowrap; }
  .cat-table thead tr th:first-child { border-radius:10px 0 0 0; }
  .cat-table thead tr th:last-child  { border-radius:0 10px 0 0; }
  .cat-table tbody tr { border-bottom:1px solid #f1f5f9; transition:background 0.15s; }
  .cat-table tbody tr:hover { background:#fafafa; }
  .cat-table tbody tr:last-child { border-bottom:none; }
  .cat-table tbody td { padding:13px 16px; font-size:13.5px; color:#334155; vertical-align:middle; }

  .sno-badge { background:#f1f5f9; color:#64748b; font-size:12px; font-weight:600; padding:3px 9px; border-radius:6px; }
  .slider-img { width:80px; height:52px; object-fit:cover; border-radius:10px; border:2px solid #f1f5f9; cursor:zoom-in; transition:transform 0.2s; }
  .slider-img:hover { transform:scale(1.08); }
  .no-img { width:80px; height:52px; background:#f1f5f9; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:20px; }

  .status-btn { border:none; border-radius:20px; padding:5px 14px; font-size:12px; font-weight:600; cursor:pointer; transition:all 0.2s; }
  .status-btn.active   { background:#dcfce7; color:#16a34a; }
  .status-btn.inactive { background:#f1f5f9; color:#94a3b8; }

  .btn-edit { background:#eff6ff; color:#3b82f6; border:none; border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer; transition:all 0.2s; }
  .btn-edit:hover { background:#3b82f6; color:#fff; }
  .btn-del  { background:#fff1f2; color:#e63946; border:none; border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer; transition:all 0.2s; }
  .btn-del:hover { background:#e63946; color:#fff; }

  .empty-state { text-align:center; padding:48px 20px; color:#94a3b8; }
  .empty-state i { font-size:48px; margin-bottom:12px; display:block; }

  /* pagination */
  .pagination-wrapper { display:flex; align-items:center; justify-content:space-between; padding:16px 22px; border-top:1px solid #f1f5f9; flex-wrap:wrap; gap:10px; }
  .pagination-info { font-size:13px; color:#64748b; }
  .pagination-info strong { color:#0f172a; }
  .pag-btns { display:flex; gap:6px; align-items:center; }
  .pag-btn { min-width:36px; height:36px; border:1.5px solid #e2e8f0; border-radius:8px; background:#fff; color:#334155; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; text-decoration:none; transition:all 0.2s; padding:0 10px; }
  .pag-btn:hover { border-color:#e63946; color:#e63946; background:#fff1f2; }
  .pag-btn.active { background:linear-gradient(135deg,#e63946,#c1121f); color:#fff; border-color:transparent; box-shadow:0 4px 12px rgba(230,57,70,0.3); }
  .pag-btn.disabled { opacity:0.4; pointer-events:none; }

  /* image zoom modal */
  .img-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
  .img-modal-overlay.active { display:flex; }
  .img-modal-box { position:relative; animation:zoomIn 0.2s ease; }
  @keyframes zoomIn { from{transform:scale(0.8);opacity:0} to{transform:scale(1);opacity:1} }
  .img-modal-box img { max-width:480px; max-height:480px; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.4); display:block; }
  .img-modal-close { position:absolute; top:-14px; right:-14px; width:32px; height:32px; background:#e63946; color:#fff; border:none; border-radius:50%; font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; }

  /* edit modal */
  .modal-content { border:none; border-radius:16px; overflow:hidden; }
  .modal-header-dark { background:#0f172a; padding:16px 22px; display:flex; align-items:center; justify-content:space-between; }
  .modal-header-dark span { color:#fff; font-size:15px; font-weight:600; }
  .modal-header-dark button { background:none; border:none; color:rgba(255,255,255,0.6); font-size:20px; cursor:pointer; }
</style>

<div class="cat-wrapper">

  <div class="page-heading">
    <i class="las la-images" style="color:#e63946; margin-right:8px;"></i>
    Manage <span>Sliders</span>
  </div>

  <!-- CREATE FORM -->
  <div class="dash-card">
    <div class="dash-card-header">
      <i class="las la-plus-circle"></i>
      <span>Add New Slider</span>
    </div>
    <div class="dash-card-body">
      <form action="/sliders/store" method="POST" enctype="multipart/form-data">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Title</label>
            <input type="text" name="title" class="form-control" placeholder="Slider title" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Description</label>
            <input type="text" name="description" class="form-control" placeholder="Short description">
          </div>
          <div class="col-md-4">
            <label class="form-label">Image</label>
            <div class="file-upload-wrapper">
              <label class="file-upload-label" for="sliderImgInput">
                <div class="upload-icon"><i class="las la-cloud-upload-alt"></i></div>
                <div class="upload-text"><strong>Click to upload</strong>PNG, JPG supported</div>
              </label>
              <input type="file" id="sliderImgInput" name="image" accept="image/*">
              <div class="file-name-display" id="sliderFileName"></div>
            </div>
          </div>
          <div class="col-12 text-end">
            <button type="submit" class="btn-create"><i class="las la-plus" style="margin-right:6px;"></i>Add Slider</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- LIST -->
  <div class="dash-card">
    <div class="dash-card-header">
      <i class="las la-th-list"></i>
      <span>Slider List</span>
    </div>

    <!-- Search -->
    <form class="search-bar" method="GET" action="/sliders">
      <input type="text" name="search" value="<%= search %>" placeholder="Search by title or description...">
      <button type="submit" class="btn-search"><i class="las la-search"></i> Search</button>
      <% if (search) { %>
        <a href="/sliders" class="btn-clear-s"><i class="las la-times"></i> Clear</a>
      <% } %>
    </form>

    <div style="padding:0;">
      <div class="table-responsive">
        <table class="cat-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Image</th>
              <th>Title</th>
              <th>Description</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (sliders && sliders.length > 0) { %>
              <% sliders.forEach((slider, idx) => { %>
                <tr id="sliderRow-<%= slider.id %>">
                  <td><span class="sno-badge"><%= (currentPage-1)*10 + idx + 1 %></span></td>
                  <td>
                    <% if (slider.image) { %>
                      <img src="<%= slider.image %>" class="slider-img" onclick="openImgModal(this.src)">
                    <% } else { %>
                      <div class="no-img"><i class="las la-image"></i></div>
                    <% } %>
                  </td>
                  <td style="font-weight:600; color:#0f172a;"><%= slider.title %></td>
                  <td style="color:#64748b; max-width:200px;"><%= slider.description || '—' %></td>
                  <td>
                    <button class="status-btn <%= slider.status %>" data-id="<%= slider.id %>">
                      <%= slider.status === 'active' ? '✓ Active' : '✗ Inactive' %>
                    </button>
                  </td>
                  <td style="display:flex; gap:6px;">
                    <button class="btn-edit"
                      data-id="<%= slider.id %>"
                      data-title="<%= encodeURIComponent(slider.title||'') %>"
                      data-desc="<%= encodeURIComponent(slider.description||'') %>"
                      data-image="<%= slider.image||'' %>">
                      <i class="las la-pen"></i> Edit
                    </button>
                    <button class="btn-del delete-btn" data-id="<%= slider.id %>">
                      <i class="las la-trash"></i> Delete
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <i class="las la-images"></i>
                    <p>No sliders found.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="pagination-wrapper">
        <div class="pagination-info">Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong></div>
        <div class="pag-btns">
          <a href="/sliders?page=<%= currentPage-1 %>&search=<%= search %>" class="pag-btn <%= currentPage<=1?'disabled':'' %>"><i class="las la-angle-left"></i></a>
          <% for(let i=1;i<=totalPages;i++){ %>
            <% if(i===1||i===totalPages||(i>=currentPage-1&&i<=currentPage+1)){ %>
              <a href="/sliders?page=<%= i %>&search=<%= search %>" class="pag-btn <%= i===currentPage?'active':'' %>"><%= i %></a>
            <% } else if(i===currentPage-2||i===currentPage+2){ %>
              <span class="pag-btn disabled">…</span>
            <% } %>
          <% } %>
          <a href="/sliders?page=<%= currentPage+1 %>&search=<%= search %>" class="pag-btn <%= currentPage>=totalPages?'disabled':'' %>"><i class="las la-angle-right"></i></a>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Image Zoom Modal -->
<div class="img-modal-overlay" id="imgModal" onclick="if(event.target===this)this.classList.remove('active')">
  <div class="img-modal-box">
    <button class="img-modal-close" onclick="document.getElementById('imgModal').classList.remove('active')">✕</button>
    <img id="imgModalSrc" src="" alt="">
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header-dark">
        <span><i class="las la-pen" style="color:#e63946;margin-right:8px;"></i>Edit Slider</span>
        <button data-bs-dismiss="modal">✕</button>
      </div>
      <div class="dash-card-body">
        <form id="editForm" enctype="multipart/form-data">
          <input type="hidden" id="edit-id" name="id">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Title</label>
              <input type="text" id="edit-title" name="title" class="form-control" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Description</label>
              <input type="text" id="edit-desc" name="description" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Image <span style="color:#94a3b8;font-weight:400;">(leave empty to keep current)</span></label>
              <div class="file-upload-wrapper">
                <label class="file-upload-label" for="editImgInput">
                  <div class="upload-icon"><i class="las la-cloud-upload-alt"></i></div>
                  <div class="upload-text"><strong>Click to change image</strong>PNG, JPG supported</div>
                </label>
                <input type="file" id="editImgInput" name="image" accept="image/*">
                <div class="file-name-display" id="editFileName"></div>
              </div>
            </div>
            <div class="col-md-6" style="display:flex;align-items:flex-end;">
              <img id="edit-current-img" src="" style="width:100px;height:64px;object-fit:cover;border-radius:10px;border:2px solid #f1f5f9;display:none;">
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn-create">Update Slider</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // file input display
  document.getElementById('sliderImgInput').addEventListener('change', function(){
    const d = document.getElementById('sliderFileName');
    if(this.files[0]){ d.textContent='📎 '+this.files[0].name; d.style.display='block'; }
  });
  document.getElementById('editImgInput').addEventListener('change', function(){
    const d = document.getElementById('editFileName');
    if(this.files[0]){ d.textContent='📎 '+this.files[0].name; d.style.display='block'; }
  });

  // image zoom
  function openImgModal(src){
    document.getElementById('imgModalSrc').src = src;
    document.getElementById('imgModal').classList.add('active');
  }
  document.addEventListener('keydown', e => { if(e.key==='Escape') document.getElementById('imgModal').classList.remove('active'); });

  // open edit modal
  function openEditModal(id, title, desc, image){
    document.getElementById('edit-id').value    = id;
    document.getElementById('edit-title').value = title;
    document.getElementById('edit-desc').value  = desc;
    const img = document.getElementById('edit-current-img');
    if(image){ img.src=image; img.style.display='block'; } else { img.style.display='none'; }
    document.getElementById('editFileName').style.display='none';
    new bootstrap.Modal(document.getElementById('editModal')).show();
  }

  $(document).ready(function(){

    // edit btn click
    $(document).on('click', '.btn-edit', function(){
      const id    = $(this).data('id');
      const title = decodeURIComponent($(this).data('title'));
      const desc  = decodeURIComponent($(this).data('desc'));
      const image = $(this).data('image');
      document.getElementById('edit-id').value    = id;
      document.getElementById('edit-title').value = title;
      document.getElementById('edit-desc').value  = desc;
      const img = document.getElementById('edit-current-img');
      if(image){ img.src=image; img.style.display='block'; } else { img.style.display='none'; }
      document.getElementById('editFileName').style.display='none';
      new bootstrap.Modal(document.getElementById('editModal')).show();
    });

    // status toggle
    $(document).on('click', '.status-btn', function(){
      const btn = $(this);
      $.post('/sliders/toggle/'+btn.data('id'), function(res){
        if(res.success){
          if(res.newStatus==='active'){
            btn.removeClass('inactive').addClass('active').text('✓ Active');
          } else {
            btn.removeClass('active').addClass('inactive').text('✗ Inactive');
          }
        }
      });
    });

    // delete
    $(document).on('click', '.delete-btn', function(){
      if(!confirm('Delete this slider?')) return;
      const id = $(this).data('id');
      $.ajax({
        url: '/sliders/delete/'+id, type:'DELETE',
        success: function(res){
          if(res.success) $('#sliderRow-'+id).fadeOut(300, function(){ $(this).remove(); });
          else alert('Error deleting slider.');
        }
      });
    });

    // update
    $('#editForm').submit(function(e){
      e.preventDefault();
      $.ajax({
        url: '/sliders/update', type:'POST',
        data: new FormData(this),
        processData:false, contentType:false,
        success: function(res){
          if(res.success){ bootstrap.Modal.getInstance(document.getElementById('editModal')).hide(); location.reload(); }
          else alert('Update failed.');
        }
      });
    });

  });
</script>
