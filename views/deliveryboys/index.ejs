<style>
  .cat-wrapper { padding: 28px 20px; background: #f8fafc; min-height: 100vh; }
  .page-heading { font-size: 22px; font-weight: 700; color: #0f172a; margin-bottom: 24px; }
  .page-heading span { color: #e63946; }

  .dash-card { background: #fff; border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.07); overflow: hidden; margin-bottom: 28px; }
  .dash-card-header { background: #0f172a; padding: 16px 22px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
  .dash-card-header-left { display: flex; align-items: center; gap: 10px; }
  .dash-card-header i { color: #e63946; font-size: 20px; }
  .dash-card-header span { color: #fff; font-size: 15px; font-weight: 600; }

  .search-bar { padding: 16px 22px; border-bottom: 1px solid #f1f5f9; display: flex; gap: 10px; flex-wrap: wrap; }
  .search-bar input { flex:1; min-width:200px; max-width:360px; border:1.5px solid #e2e8f0; border-radius:10px; padding:9px 14px; font-size:13.5px; color:#1e293b; outline:none; transition:border-color 0.2s; }
  .search-bar input:focus { border-color:#e63946; box-shadow:0 0 0 3px rgba(230,57,70,0.1); }
  .btn-search { background:#0f172a; color:#fff; border:none; border-radius:10px; padding:9px 18px; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; }
  .btn-clear-s { background:#f1f5f9; color:#64748b; border:none; border-radius:10px; padding:9px 14px; font-size:13px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:6px; }

  .cat-table { width:100%; border-collapse:separate; border-spacing:0; }
  .cat-table thead tr th { background:#0f172a; color:rgba(255,255,255,0.75); font-size:12px; font-weight:600; letter-spacing:0.6px; text-transform:uppercase; padding:13px 16px; border:none; white-space:nowrap; }
  .cat-table thead tr th:first-child { border-radius:10px 0 0 0; }
  .cat-table thead tr th:last-child  { border-radius:0 10px 0 0; }
  .cat-table tbody tr { border-bottom:1px solid #f1f5f9; transition:background 0.15s; }
  .cat-table tbody tr:hover { background:#fafafa; }
  .cat-table tbody tr:last-child { border-bottom:none; }
  .cat-table tbody td { padding:13px 16px; font-size:13px; color:#334155; vertical-align:middle; }

  .sno-badge { background:#f1f5f9; color:#64748b; font-size:12px; font-weight:600; padding:3px 9px; border-radius:6px; }
  .db-img { width:44px; height:44px; object-fit:cover; border-radius:50%; border:2px solid #f1f5f9; cursor:zoom-in; }
  .no-img { width:44px; height:44px; background:#f1f5f9; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:18px; }

  .badge-pill { font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; }
  .s-active   { background:#dcfce7; color:#16a34a; }
  .s-inactive { background:#f1f5f9; color:#94a3b8; }
  .s-busy     { background:#fff7ed; color:#ea580c; }
  .s-free     { background:#f0fdf4; color:#16a34a; }
  .s-on       { background:#dcfce7; color:#16a34a; }
  .s-off      { background:#fee2e2; color:#e63946; }

  .order-count { background:#eff6ff; color:#3b82f6; font-size:12px; font-weight:700; padding:3px 10px; border-radius:6px; }

  .btn-view { background:#fff7ed; color:#ea580c; border:none; border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:4px; transition:all 0.2s; }
  .btn-view:hover { background:#ea580c; color:#fff; }

  .doc-img { width:48px; height:36px; object-fit:cover; border-radius:6px; border:1px solid #e2e8f0; cursor:zoom-in; }

  .empty-state { text-align:center; padding:48px 20px; color:#94a3b8; }
  .empty-state i { font-size:48px; margin-bottom:12px; display:block; }

  .pagination-wrapper { display:flex; align-items:center; justify-content:space-between; padding:16px 22px; border-top:1px solid #f1f5f9; flex-wrap:wrap; gap:10px; }
  .pagination-info { font-size:13px; color:#64748b; }
  .pagination-info strong { color:#0f172a; }
  .pag-btns { display:flex; gap:6px; align-items:center; }
  .pag-btn { min-width:36px; height:36px; border:1.5px solid #e2e8f0; border-radius:8px; background:#fff; color:#334155; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; text-decoration:none; transition:all 0.2s; padding:0 10px; }
  .pag-btn:hover { border-color:#e63946; color:#e63946; background:#fff1f2; }
  .pag-btn.active { background:linear-gradient(135deg,#e63946,#c1121f); color:#fff; border-color:transparent; }
  .pag-btn.disabled { opacity:0.4; pointer-events:none; }

  .img-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
  .img-modal-overlay.active { display:flex; }
  .img-modal-box { position:relative; animation:zoomIn 0.2s ease; }
  @keyframes zoomIn { from{transform:scale(0.8);opacity:0} to{transform:scale(1);opacity:1} }
  .img-modal-box img { max-width:480px; max-height:480px; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.4); display:block; }
  .img-modal-close { position:absolute; top:-14px; right:-14px; width:32px; height:32px; background:#e63946; color:#fff; border:none; border-radius:50%; font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
</style>

<div class="cat-wrapper">
  <div class="page-heading">
    <i class="las la-motorcycle" style="color:#e63946; margin-right:8px;"></i>
    Manage <span>Delivery Boys</span>
  </div>

  <div class="dash-card">
    <div class="dash-card-header">
      <div class="dash-card-header-left">
        <i class="las la-motorcycle"></i>
        <span>Delivery Boy List</span>
      </div>
    </div>

    <form class="search-bar" method="GET" action="/delivery-boys">
      <input type="text" name="search" value="<%= search %>" placeholder="Search by name, mobile, email...">
      <button type="submit" class="btn-search"><i class="las la-search"></i> Search</button>
      <% if (search) { %>
        <a href="/delivery-boys" class="btn-clear-s"><i class="las la-times"></i> Clear</a>
      <% } %>
    </form>

    <div style="padding:0;">
      <div class="table-responsive">
        <table class="cat-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Photo</th>
              <th>Name</th>
              <th>Mobile</th>
              <th>Email</th>
              <th>Vehicle</th>
              <th>Identity</th>
              <th>ID Image</th>
              <th>License No.</th>
              <th>License Img</th>
              <th>Status</th>
              <th>Orders</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (boys && boys.length > 0) { %>
              <% boys.forEach((b, idx) => { %>
                <tr>
                  <td><span class="sno-badge"><%= (page-1)*10 + idx + 1 %></span></td>
                  <td>
                    <% if (b.profile_picture) { %>
                      <img src="<%= b.profile_picture %>" class="db-img" onclick="openImg(this.src)">
                    <% } else { %>
                      <div class="no-img"><i class="las la-user"></i></div>
                    <% } %>
                  </td>
                  <td style="font-weight:600; color:#0f172a; white-space:nowrap;"><%= b.first_name %> <%= b.last_name %></td>
                  <td><%= b.mobile_number %></td>
                  <td style="color:#64748b;"><%= b.email %></td>
                  <td><span class="badge-pill s-free" style="background:#f1f5f9;color:#334155;"><%= b.vehicle_type %></span></td>
                  <td>
                    <div style="font-size:11px;color:#64748b;"><%= b.identity_type %></div>
                    <div style="font-size:12px;font-weight:600;color:#0f172a;"><%= b.identity_number %></div>
                  </td>
                  <td>
                    <% if (b.identity_image) { %>
                      <img src="<%= b.identity_image %>" class="doc-img" onclick="openImg(this.src)">
                    <% } else { %>
                      <span style="color:#94a3b8;font-size:12px;">—</span>
                    <% } %>
                  </td>
                  <td style="font-size:12px;"><%= b.driving_license_number %></td>
                  <td>
                    <% if (b.driving_license_image) { %>
                      <img src="<%= b.driving_license_image %>" class="doc-img" onclick="openImg(this.src)">
                    <% } else { %>
                      <span style="color:#94a3b8;font-size:12px;">—</span>
                    <% } %>
                  </td>
                  <td><span class="badge-pill <%= b.status == 1 ? 's-active' : 's-inactive' %>"><%= b.status == 1 ? 'Active' : 'Inactive' %></span></td>
                  <td><span class="order-count"><%= b.total_orders %> orders</span></td>
                  <td>
                    <a href="/delivery-boys/<%= b.id %>/orders" class="btn-view">
                      <i class="las la-eye"></i> View Orders
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="15"><div class="empty-state"><i class="las la-motorcycle"></i><p>No delivery boys found.</p></div></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <div class="pagination-wrapper">
        <div class="pagination-info">Page <strong><%= page %></strong> of <strong><%= totalPages %></strong></div>
        <div class="pag-btns">
          <a href="/delivery-boys?page=<%= page-1 %>&search=<%= search %>" class="pag-btn <%= page<=1?'disabled':'' %>"><i class="las la-angle-left"></i></a>
          <% for(let i=1;i<=totalPages;i++){ %>
            <% if(i===1||i===totalPages||(i>=page-1&&i<=page+1)){ %>
              <a href="/delivery-boys?page=<%= i %>&search=<%= search %>" class="pag-btn <%= i===page?'active':'' %>"><%= i %></a>
            <% } else if(i===page-2||i===page+2){ %>
              <span class="pag-btn disabled">…</span>
            <% } %>
          <% } %>
          <a href="/delivery-boys?page=<%= page+1 %>&search=<%= search %>" class="pag-btn <%= page>=totalPages?'disabled':'' %>"><i class="las la-angle-right"></i></a>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<div class="img-modal-overlay" id="imgModal" onclick="if(event.target===this)this.classList.remove('active')">
  <div class="img-modal-box">
    <button class="img-modal-close" onclick="document.getElementById('imgModal').classList.remove('active')">✕</button>
    <img id="imgModalSrc" src="" alt="">
  </div>
</div>

<script>
  function openImg(src) {
    document.getElementById('imgModalSrc').src = src;
    document.getElementById('imgModal').classList.add('active');
  }
  document.addEventListener('keydown', e => { if(e.key==='Escape') document.getElementById('imgModal').classList.remove('active'); });
</script>
