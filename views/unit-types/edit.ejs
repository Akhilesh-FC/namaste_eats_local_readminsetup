<!DOCTYPE html>
<html>
<head>
  <title>Edit Unit Type</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-5">
  <h2 class="mb-4">Edit Unit Type</h2>
  <div class="card">
    <div class="card-body">
      <form action="/admin/unit-types/update/<%= unitType.id %>" method="POST">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-control" value="<%= unitType.name %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Short Code</label>
          <input type="text" name="short_code" class="form-control" value="<%= unitType.short_code %>" required>
        </div>
        <button type="submit" class="btn btn-success">Update</button>
        <a href="/admin/unit-types" class="btn btn-secondary">Cancel</a>
      </form>
    </div>
  </div>
</body>
</html>
