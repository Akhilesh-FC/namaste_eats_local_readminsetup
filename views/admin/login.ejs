<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>NamasteEats - Admin Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, rgba(255, 87, 34, 0.85), rgba(255, 193, 7, 0.85)),
                  url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092?q=80&w=1200') no-repeat center center/cover;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .login-box {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(8px);
      padding: 40px 35px;
      border-radius: 20px;
      box-shadow: 0 8px 35px rgba(0,0,0,0.2);
      width: 100%;
      max-width: 400px;
      animation: fadeInUp 1s ease;
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .login-box h3 {
      font-weight: 600;
      color: #ff5722;
      text-align: center;
      margin-bottom: 25px;
    }

    .form-control {
      border-radius: 10px;
      height: 50px;
      border: 1px solid #ddd;
      transition: 0.3s;
    }

    .form-control:focus {
      border-color: #ff7043;
      box-shadow: 0 0 8px rgba(255, 87, 34, 0.3);
    }

    .btn-login {
      background: #ff5722;
      border: none;
      color: white;
      border-radius: 10px;
      height: 50px;
      font-weight: 500;
      transition: 0.3s;
    }

    .btn-login:hover {
      background: #e64a19;
      transform: scale(1.03);
    }

    .footer-text {
      text-align: center;
      margin-top: 15px;
      font-size: 14px;
      color: #555;
    }

    .logo {
      display: block;
      margin: 0 auto 15px auto;
      width: 80px;
      height: 80px;
      object-fit: contain;
    }
  </style>
</head>
<body>

  <div class="login-box">
    <img src="https://cdn-icons-png.flaticon.com/512/857/857681.png" alt="NamasteEats Logo" class="logo">
    <h3>Admin Login</h3>
<form action="/admin/login" method="POST">


  <div class="mb-3">
      <label class="form-label">Email address</label>
      <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
  </div>

  <div class="mb-3">
      <label class="form-label">Password</label>
      <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger text-center"><%= error %></div>
  <% } %>

  <button type="submit" class="btn btn-login w-100">Login</button>

</form>

  </div>

</body>
</html>
