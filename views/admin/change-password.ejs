<style>
  .cp-wrapper {
    padding: 28px 20px;
    background: #f8fafc;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .page-heading { font-size: 22px; font-weight: 700; color: #0f172a; margin-bottom: 24px; }
  .page-heading span { color: #e63946; }

  .cp-card {
    background: #fff;
    border: none;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    overflow: hidden;
    max-width: 480px;
    width: 100%;
  }
  .cp-card-header {
    background: #0f172a;
    padding: 16px 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cp-card-header i { color: #e63946; font-size: 20px; }
  .cp-card-header span { color: #fff; font-size: 15px; font-weight: 600; }
  .cp-card-body { padding: 28px 24px; }

  .form-label {
    font-size: 13px;
    font-weight: 600;
    color: #374151;
    margin-bottom: 6px;
    display: block;
  }

  .input-wrap { position: relative; }
  .input-wrap input {
    width: 100%;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-size: 14px;
    padding: 10px 42px 10px 14px;
    color: #1e293b;
    background: #f8fafc;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    box-sizing: border-box;
  }
  .input-wrap input:focus {
    border-color: #e63946;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(230,57,70,0.1);
  }
  .input-wrap .eye-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    font-size: 16px;
    padding: 0;
    line-height: 1;
  }
  .input-wrap .eye-btn:hover { color: #e63946; }

  .alert-danger-custom {
    background: #fff1f2;
    border: 1.5px solid #fecaca;
    color: #dc2626;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn-submit {
    width: 100%;
    background: linear-gradient(135deg, #e63946, #c1121f);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 12px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    margin-top: 8px;
  }
  .btn-submit:hover { opacity: 0.88; transform: translateY(-1px); }

  .field-group { margin-bottom: 18px; }
</style>

<div class="cp-wrapper">

  <div class="page-heading">
    <i class="las la-key" style="color:#e63946; margin-right:8px;"></i>
    Change <span>Password</span>
  </div>

  <div class="cp-card">
    <div class="cp-card-header">
      <i class="las la-lock"></i>
      <span>Update Your Password</span>
    </div>
    <div class="cp-card-body">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert-danger-custom">
          <i class="las la-exclamation-circle"></i>
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/change-password">

        <div class="field-group">
          <label class="form-label">Current Password</label>
          <div class="input-wrap">
            <input type="password" name="old_password" id="old_password" placeholder="Enter current password" required>
            <button type="button" class="eye-btn" onclick="togglePass('old_password', this)">
              <i class="las la-eye"></i>
            </button>
          </div>
        </div>

        <div class="field-group">
          <label class="form-label">New Password</label>
          <div class="input-wrap">
            <input type="password" name="new_password" id="new_password" placeholder="Enter new password" required>
            <button type="button" class="eye-btn" onclick="togglePass('new_password', this)">
              <i class="las la-eye"></i>
            </button>
          </div>
        </div>

        <div class="field-group">
          <label class="form-label">Confirm New Password</label>
          <div class="input-wrap">
            <input type="password" name="confirm_password" id="confirm_password" placeholder="Re-enter new password" required>
            <button type="button" class="eye-btn" onclick="togglePass('confirm_password', this)">
              <i class="las la-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-submit">
          <i class="las la-check-circle" style="margin-right:6px;"></i> Update Password
        </button>

      </form>
    </div>
  </div>
</div>

<script>
  function togglePass(id, btn) {
    const input = document.getElementById(id);
    const icon  = btn.querySelector('i');
    if (input.type === 'password') {
      input.type = 'text';
      icon.className = 'las la-eye-slash';
    } else {
      input.type = 'password';
      icon.className = 'las la-eye';
    }
  }
</script>
