<!-- ── ACTIVE LINK SCRIPT ── -->
<script>
document.addEventListener("DOMContentLoaded", function () {
  const currentPath = window.location.pathname;
  const allLi = document.querySelectorAll("#iq-sidebar-toggle li");

  allLi.forEach(li => li.classList.remove("active", "active-menu"));

  allLi.forEach(li => {
    const a = li.querySelector("a");
    if (a && a.getAttribute("href") === currentPath) {
      li.classList.add("active", "active-menu");
    }
  });
});
</script>
