<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body { 
      font-family: 'Inter', sans-serif; 
      background: #f4f5f7; 
      padding: 0px; 
    }
    .card { 
      border-radius: 12px; 
      box-shadow: 0 6px 20px rgba(0,0,0,0.1); 
      background: #fff;
    }
    table th, table td { 
      vertical-align: middle; 
      text-align: center;
    }
    img.user-thumb { 
      border-radius: 50%; 
      width: 60px; 
      height: 60px;
      border: 2px solid #ddd; 
      cursor: pointer;
      object-fit: cover;
      transition: transform 0.2s ease;
    }
    img.user-thumb:hover { transform: scale(1.08); }

    .btn-toggle { 
      cursor: pointer; 
      border-radius: 20px; 
      padding: 5px 15px;
      font-size: 0.9rem;
    }
    .toggle-active { background-color: #28a745; color: #fff; }
    .toggle-inactive { background-color: #dc3545; color: #fff; }

    h1 { 
      font-weight: 700; 
      margin-bottom: 25px; 
      color: #333;
    }

    /* Image Modal */
    .modal-img {
      display: none;
      position: fixed;
      z-index: 9999;
      padding-top: 60px;
      left: 0; top: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.8);
      overflow: auto;
    }
    .modal-img-content {
      margin: auto;
      display: block;
      width: 80%;
      max-width: 700px;
      border-radius: 10px;
      box-shadow: 0 0 20px rgba(255,255,255,0.3);
    }
    .modal-close {
      position: absolute;
      top: 15px; right: 25px;
      color: #fff;
      font-size: 35px;
      font-weight: bold;
      cursor: pointer;
    }
    .modal-close:hover { color: #ff5252; }
  </style>
</head>
<body>

<div class="container-fluid">

  <h1>Users</h1>

  <div class="card">
    <div class="card-body table-responsive">
      <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark text-center">
          <tr>
            <th>ID</th>
            
            <th>Name</th>
           
            <th>Email</th>
            <th>Mobile</th>
            <th>DOB</th>
            <th>Anniversary</th>
            <th>Gender</th>
           
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.id || 'N/A' %></td>
              
              <td><%= u.name || 'N/A' %></td>
             
              <td><%= u.email || 'N/A' %></td>
              <td><%= u.mobile_no || 'N/A' %></td>
              <td><%= u.dob ? new Date(u.dob).toLocaleDateString() : 'N/A' %></td>
              <td><%= u.anniversary ? new Date(u.anniversary).toLocaleDateString() : 'N/A' %></td>
              <td><%= u.gender || 'N/A' %></td>
              
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal for Image Zoom -->
<div id="imgModal" class="modal-img">
  <span class="modal-close">&times;</span>
  <img class="modal-img-content" id="imgFull">
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function(){
  // Toggle Active/Inactive
  $('.btn-toggle').click(function(){
    const btn = $(this);
    const id = btn.data('id');
    $.post(`/users/${id}/toggle`, function(res){
      if(res.success){
        if(res.status==1){
          btn.removeClass('toggle-inactive').addClass('toggle-active').text('Active');
        } else {
          btn.removeClass('toggle-active').addClass('toggle-inactive').text('Inactive');
        }
      }
    });
  });

  // Image Zoom Modal
  const modal = $('#imgModal');
  const modalImg = $('#imgFull');

  $('.user-thumb').click(function(){
    const fullUrl = $(this).data('full');
    modal.show();
    modalImg.attr('src', fullUrl);
  });

  $('.modal-close').click(function(){
    modal.hide();
  });

  $(window).click(function(e){
    if(e.target.id === 'imgModal') modal.hide();
  });
});
</script>

</body>
</html>
